OPENAI_API_KEY=sk-...
PORT=8787
LLM_PROXY_HOST=127.0.0.1
LLM_ALLOWED_ORIGINS=http://127.0.0.1:5176
# Set in beta deployment to require a valid cloud session before LLM calls.
# LLM_AUTH_API_BASE=https://api.example.com/api
# Raise this for larger PDF uploads after checking your proxy/body limits.
LLM_MAX_BODY_BYTES=12582912

# API email verification. Without SMTP, api-server/server.py prints dev codes
# to its terminal and returns devCode for local testing.
QUANTGYM_REQUIRE_EMAIL_VERIFICATION=1
QUANTGYM_EMAIL_CODE_TTL_MINUTES=10
QUANTGYM_EMAIL_CODE_COOLDOWN_SECONDS=60
QUANTGYM_EMAIL_DEV_CODE_RESPONSE=1
# QUANTGYM_SMTP_HOST=smtp.example.com
# QUANTGYM_SMTP_PORT=587
# QUANTGYM_SMTP_USERNAME=mailer@example.com
# QUANTGYM_SMTP_PASSWORD=app-password
# QUANTGYM_SMTP_FROM=QuantGym <mailer@example.com>
